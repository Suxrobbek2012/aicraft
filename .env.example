# ============================================================
# AICRAFT — Environment Variables Example
# .env nomiga nusxa oling va to'ldiring
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=aicraft
APP_URL=http://localhost:3011
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3010,http://localhost:3011

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://goai:goai_password@localhost:5432/goai_db

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ────────────────────────────────────────────────
# openssl rand -hex 32 bilan yarating
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
ENCRYPTION_KEY=32_char_hex_key_for_aes_256_encryption_here_ok

# ─── AI — Groq (rotation, 6 ta key) ─────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_5=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_6=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── AI — Boshqa provayderlar (ixtiyoriy) ────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Ollama (local AI, ixtiyoriy) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# ─── Fayl saqlash ────────────────────────────────────────────
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── Email ───────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=aicraft <noreply@aicraft.app>

# ─── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@aicraft.app
ADMIN_PASSWORD=Admin123!

# ─── Log ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3011
NEXT_PUBLIC_WS_URL=ws://localhost:4000
