# ============================================================
# GO AI - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- App ---
NODE_ENV=development
APP_NAME="Go AI"
APP_URL=http://localhost:3010
API_URL=http://localhost:4000

# --- Database ---
DATABASE_URL=postgresql://goai:goai_password@localhost:5432/goai_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# --- Encryption ---
ENCRYPTION_KEY=32_char_hex_key_for_aes_256_encryption

# --- AI Providers ---
# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_DEFAULT_MODEL=gemini-1.5-pro

# xAI Grok
XAI_API_KEY=
XAI_DEFAULT_MODEL=grok-2

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_DEFAULT_MODEL=llama-3.1-sonar-large-128k-online

# Ollama (local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# --- File Storage ---
STORAGE_PROVIDER=local
# local | s3 | r2

# Local Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- Email ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Go AI <noreply@goai.app>"

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Stripe (Billing) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FREE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ULTRA_PRICE_ID=

# --- Logging ---
LOG_LEVEL=info
LOG_PRETTY=true

# --- Monitoring ---
SENTRY_DSN=

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS ---
CORS_ORIGINS=http://localhost:3010

# --- Admin ---
ADMIN_EMAIL=admin@goai.app
ADMIN_PASSWORD=change_this_in_production

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_NAME="Go AI"
