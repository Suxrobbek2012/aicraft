# ============================================================
# AICRAFT API — PRODUCTION ENV
# Quyidagi barcha bo'sh qiymatlarni to'ldiring
# ============================================================

NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# ─── App URLs (o'zingizning domeyningiz) ────────────────────
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:PASSWORD@HOST:6379  # Password bilan

# ─── JWT (kamida 64 belgili random string) ───────────────────
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_SECRET_USE_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=CHANGE_THIS_ANOTHER_64_CHAR_RANDOM_SECRET_OPENSSL
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Encryption (32 belgili hex) ─────────────────────────────
ENCRYPTION_KEY=CHANGE_THIS_32_CHAR_HEX_KEY_OPENSSL_RAND_HEX_16

# ─── Groq API Keys (rotation) ────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_5=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_6=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Ollama (agar ishlatmasangiz bo'sh qoldiring) ────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# ─── File Storage ────────────────────────────────────────────
STORAGE_PROVIDER=local
# Production uchun s3 yoki r2 tavsiya etiladi:
# STORAGE_PROVIDER=r2
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Cloudflare R2 (agar ishlatilsa)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# ─── Email ───────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=aicraft <noreply@yourdomain.com>

# ─── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false
